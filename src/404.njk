---
layout: base.njk
title: Page non trouvée
permalink: /404.html
locale: fr
availableLocales:
  - fr
robots: noindex,follow
---

{% set t = translations[locale] or translations['fr'] %}

<style>
@layer components {
  .error-container {
    max-width: 48rem;
    margin: 0 auto;
    padding: var(--spacing-3xl) var(--spacing-xl);
    text-align: center;
  }

  .error-code {
    font-size: clamp(6rem, 15vw, 10rem);
    font-weight: 800;
    color: var(--primary-color);
    line-height: 1;
    margin-bottom: var(--spacing-md);
    letter-spacing: -0.05em;
    opacity: 0.85;
  }

  .error-road {
    width: clamp(180px, 40vw, 320px);
    height: 6px;
    background: repeating-linear-gradient(
      90deg,
      var(--secondary-color) 0px,
      var(--secondary-color) 30px,
      transparent 30px,
      transparent 50px
    );
    margin: var(--spacing-lg) auto;
    border-radius: 3px;
    position: relative;
  }

  .error-road::before {
    content: "🚐";
    position: absolute;
    left: -8px;
    top: -14px;
    font-size: 1.25rem;
    animation: driveOff 3s ease-in-out infinite;
  }

  .error-road::after {
    content: "🏠";
    position: absolute;
    right: -20px;
    top: -14px;
    font-size: 1rem;
  }

  @keyframes driveOff {
    0%, 100% { transform: translateX(0); }
    50% { transform: translateX(calc(clamp(180px, 40vw, 320px) - 30px)); }
  }

  .error-title {
    font-size: clamp(1.5rem, 3.5vw, 2rem);
    font-weight: 700;
    color: var(--primary-color);
    margin-bottom: var(--spacing-lg);
  }

  .error-body {
    font-size: 1.125rem;
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: var(--spacing-xl);
  }

  .error-body em {
    font-style: italic;
    color: var(--secondary-color);
  }

  .error-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--spacing-md);
  }

  .error-actions .btn {
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .error-actions .btn-primary {
    background: var(--secondary-color);
    color: var(--white);
  }

  .error-actions .btn-primary:hover {
    background: color-mix(in srgb, var(--secondary-color), black 10%);
  }

  .error-actions .btn-outline {
    background: transparent;
    color: var(--primary-color);
    border: 2px solid var(--primary-color);
  }

  .error-actions .btn-outline:hover {
    background: var(--primary-color);
    color: var(--white);
  }

  .error-fun-fact {
    margin-top: var(--spacing-2xl);
    padding: var(--spacing-lg);
    background: #f8f6f0;
    border-radius: 12px;
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  .error-fun-fact strong {
    color: var(--primary-color);
  }

  @container (min-width: 768px) {
    .error-container {
      padding: var(--spacing-3xl) var(--spacing-3xl);
    }
  }
}
</style>

<section class="error-container">
  <div class="error-code">404</div>
  <div class="error-road" aria-hidden="true"></div>
  <p class="error-title">{{ t.error.heading }}</p>
  <p class="error-body">
    {{ t.error.body1 | replace('La Sonnaz', '<em>La Sonnaz</em>') | safe }}
  </p>
  <p class="error-body" style="font-size:1rem;">
    {{ t.error.body2 }}
  </p>
  <div class="error-actions">
    <a href="{{ '/fr/' | relativeUrl }}" class="btn btn-primary">🏡 {{ t.home }}</a>
    <a href="{{ '/fr/eco-studio/' | relativeUrl }}" class="btn btn-outline">🛏️ {{ t.ecoStudio }}</a>
    <a href="{{ '/fr/parking/' | relativeUrl }}" class="btn btn-outline">🅿️ {{ t.menuParking }}</a>
  </div>
  <div class="error-fun-fact">
    <strong>{{ t.error.funFactLabel }}</strong>
    {{ t.error.funFact }}
  </div>
</section>
