                <option value="yéménite">Yéménite</option>
                <option value="zaïroise">Zaïroise</option>
                <option value="zambienne">Zambienne</option>
                <option value="zimbabwéenne">Zimbabwéenne</option>
              </select>
            </div>
            <div id="booking-id-document-group">
              <label class="form-label" for="booking-id-document">{{ b.idDocumentLabel }}</label>
              <input class="form-input" type="text" id="booking-id-document" name="guestIdDocumentNumber" toolparamdescription="Guest passport or identity card number (required for non-Swiss nationals).">
            </div>
          </div>
          <div id="booking-additional-guests-section" class="hidden">
            <h3 class="booking-subsection-title">{{ b.additionalGuestsTitle }}</h3>
            <div id="booking-additional-guests-container"></div>
            <template id="booking-additional-guest-template">
              <div class="booking-additional-guest grid grid-cols-2 booking-two-cols">
                <div>
                  <label class="form-label">{{ b.firstName }}</label>
                  <input class="form-input" type="text" name="additionalGuestFirstName" toolparamdescription="Additional guest first name.">
                </div>
                <div>
                  <label class="form-label">{{ b.lastName }}</label>
                  <input class="form-input" type="text" name="additionalGuestLastName" toolparamdescription="Additional guest last name.">
                </div>
              </div>
            </template>
          </div>
          <div>
            <label class="form-label" for="booking-remarks">{{ b.remarks }}</label>
            <textarea class="form-input booking-textarea" id="booking-remarks" name="remarks" rows="4" placeholder="{{ b.remarksPlaceholder }}" toolparamdescription="Optional free-text remarks about the stay, arrival, or special needs."></textarea>
          </div>
        </section>

        <section class="booking-section">
          <label class="booking-checkbox booking-checkbox-terms">
            <input type="checkbox" id="booking-terms" name="acceptedTerms" required toolparamdescription="Set to true only after the traveller has explicitly reviewed and accepted the booking and payment terms.">
            <span>
              {{ b.termsPrefix or '' }}<a href="/{{ locale }}/legal/" target="_blank" rel="noopener noreferrer">{{ b.termsLinkLabel or b.terms }}</a>{{ b.termsSuffix or '' }}
            </span>
          </label>
          {% if b.bookingRulesList %}
          <div class="booking-rules-box">
            <h3 class="booking-rules-title">{{ b.bookingRulesTitle or b.policyTitle }}</h3>
            <ul class="booking-muted-list">
              {% for item in b.bookingRulesList %}
              <li>{{ item }}</li>
              {% endfor %}
            </ul>
          </div>
          {% endif %}
          <div class="booking-actions">
            <button class="btn btn-primary booking-submit" type="submit" id="booking-submit">
              {{ b.reserveAndPay }}
            </button>
            <a href="/{{ locale }}/contact/" class="btn btn-secondary">{{ t.contactUs }}</a>
          </div>
          <div id="booking-submit-status" class="booking-submit-status" aria-live="polite"></div>
        </section>
      </form>
    </div>

    <aside class="booking-summary-column">
      <div class="card booking-summary-card">
        <div class="booking-summary-sticky">
          <h2 class="booking-summary-title">{{ b.summaryTitle }}</h2>
          <div class="booking-summary-stay">
            <span class="booking-summary-label">{{ b.stayLabel }}</span>
            <strong id="booking-stay-label">{{ b.summaryEmptyStay or '-' }}</strong>
          </div>

          <dl class="booking-breakdown" id="booking-breakdown">
            <div>
              <dt>{{ b.baseRateLabel }}</dt>
              <dd id="booking-base-amount">{{ b.summaryPendingAmount or '-' }}</dd>
            </div>
            <div>
              <dt>{{ b.touristTaxLabel }}</dt>
              <dd id="booking-tax-amount">{{ b.summaryPendingAmount or '-' }}</dd>
            </div>
            {% if showInfants %}
            <div>
              <dt>{{ b.guestSurchargeLabel or 'Guest supplements' }}</dt>
              <dd id="booking-guest-surcharge">{{ b.summaryPendingAmount or '-' }}</dd>
            </div>
            {% endif %}
            {% if showWcShower %}
            <div>
              <dt>{{ b.wcShowerLabel }}</dt>
              <dd id="booking-options-amount">{{ b.summaryPendingAmount or '-' }}</dd>
            </div>
            {% endif %}
            {% if showVehicle %}
            <div>
              <dt>{{ b.electricityLabel or 'Électricité' }}</dt>
              <dd class="booking-discount-highlight">{{ b.includedLabel or 'Inclus' }}</dd>
            </div>
            {% endif %}
            {% if showInfants %}
            <div>
              <dt>{{ b.cleaningFeeLabel or 'Cleaning fee' }}</dt>
              <dd id="booking-options-amount">{{ b.summaryPendingAmount or '-' }}</dd>
            </div>
            {% endif %}
            <div class="booking-discount-row">
              <dt>{{ b.longStayDiscountLabel }}</dt>
              <dd id="booking-long-stay-discount">{{ b.summaryPendingAmount or '-' }}</dd>
            </div>
            <div class="booking-discount-row">
              <dt>{{ b.nonRefundableDiscountLabel }}</dt>
              <dd id="booking-non-refundable-discount">{{ b.summaryPendingAmount or '-' }}</dd>
            </div>
            <div>
              <dt>{{ b.paymentFeeLabel }}</dt>
              <dd id="booking-payment-fee">{{ b.summaryPendingAmount or '-' }}</dd>
            </div>
            <div class="booking-total-row">
              <dt>{{ b.totalLabel }}</dt>
              <dd id="booking-total-amount">{{ b.summaryPendingAmount or '-' }}</dd>
            </div>
          </dl>

          <div class="booking-summary-block">
            <h3>{{ b.includedTitle }}</h3>
            <ul class="booking-muted-list">
              {% for item in b.includedList %}
              <li>{{ item }}</li>
              {% endfor %}
            </ul>
          </div>

          <div class="booking-summary-block">
            <h3>{{ b.policyTitle }}</h3>
            <ul class="booking-muted-list">
              <li>{{ b.policyFlexible }}</li>
              <li>{{ b.policyNonRefundable }}</li>
            </ul>
          </div>

          <div class="booking-summary-block">
            <h3>{{ b.supportTitle }}</h3>
            <p class="text-sm text-muted">{{ b.supportBody }}</p>
            <div class="booking-summary-links">
              <a href="/{{ locale }}/contact/">{{ t.contactUs }}</a>
              <a href="https://wa.me/41766738311" target="_blank" rel="noopener noreferrer">WhatsApp</a>
            </div>
          </div>

          <div id="booking-success-card" class="booking-success-card hidden">
            <h3>{{ b.referenceLabel }}</h3>
            <p id="booking-success-reference" class="booking-success-reference"></p>
            <p class="text-sm text-muted">
              <a id="booking-success-manage-link" href="#">{{ b.manageLink }}</a>
            </p>
            <p class="text-sm text-muted hidden" id="booking-success-payment-link-wrap">
              <a id="booking-success-payment-link" href="#" target="_blank" rel="noopener noreferrer">{{ b.paymentButtonFallback }}</a>
            </p>
          </div>
        </div>
      </div>
    </aside>
  </div>
</section>

<script src="/assets/js/booking-flow.js?v={{ build.assetVersion }}" defer></script>
