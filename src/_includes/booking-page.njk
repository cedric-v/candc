{% set t = translations[locale] or translations['fr'] %}
{% set bookingSource = bookingData or booking_ui %}
{% set b = bookingSource[locale] or bookingSource['en'] %}
{% set unitCode = bookingUnitCode or 'parking-space' %}
{% set showVehicle = b.showVehicle if b.showVehicle is defined else true %}
{% set showInfants = b.showInfants if b.showInfants is defined else false %}
{% set showWcShower = b.showWcShower if b.showWcShower is defined else true %}

<section class="page-section">
  <div class="booking-hero">
    <p class="booking-kicker">{{ b.pageKicker }}</p>
    <h1 class="hero-title">{{ b.title }}</h1>
    <p class="text-lg text-muted booking-intro">{{ b.intro }}</p>
    {% if b.overviewLinkLabel and b.overviewLinkHref %}
    <p class="booking-overview-link-wrap">
      <a class="booking-overview-link" href="{{ b.overviewLinkHref }}">{{ b.overviewLinkLabel }}</a>
    </p>
    {% endif %}
  </div>

  {% if showInfants and b.directBookingPromoText %}
  <div class="booking-promo-banner">
    <div class="booking-promo-icon">
      <svg class="booking-promo-svg" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M9 3C9 5.5 11 7.5 13.5 7.5C11 7.5 9 9.5 9 12C9 9.5 7 7.5 4.5 7.5C7 7.5 9 5.5 9 3Z" fill="currentColor"/>
        <path d="M17 11C17 12.8 18.2 14 20 14C18.2 14 17 15.2 17 17C17 15.2 15.8 14 14 14C15.8 14 17 12.8 17 11Z" fill="currentColor"/>
      </svg>
    </div>
    <div class="booking-promo-content">
      {{ b.directBookingPromoText }}
    </div>
  </div>
  {% endif %}

  {% if b.longStayPromoTitle and b.longStayPromoList %}
  <div class="booking-promo-banner booking-promo-banner-secondary">
    <div class="booking-promo-content">
      <p class="font-bold mb-2">{{ b.longStayPromoTitle }}</p>
      <ul class="booking-muted-list">
        {% for item in b.longStayPromoList %}
        <li>{{ item }}</li>
        {% endfor %}
      </ul>
    </div>
  </div>
  {% endif %}

  <div
    class="booking-shell"
    id="booking-app"
    data-locale="{{ locale }}"
    data-unit-code="{{ unitCode }}"
    data-requires-vehicle="{{ 'true' if showVehicle else 'false' }}"
    data-tool-availability-name="{{ b.webMcpAvailabilityToolName or 'check_parking_availability' }}"
    data-tool-availability-description="{{ b.webMcpAvailabilityToolDescription or 'Check whether the parking space is available for a specific stay.' }}"
    data-tool-quote-name="{{ b.webMcpQuoteToolName or 'quote_parking_stay' }}"
    data-tool-quote-description="{{ b.webMcpQuoteToolDescription or 'Calculate a direct-booking quote for the parking space.' }}"
    data-api-base="/api/booking"
    data-msg-enter-dates="{{ b.availabilityEnterDates }}"
    data-msg-checking="{{ b.checkingAvailability }}"
    data-msg-available="{{ b.datesAvailable }}"
    data-msg-unavailable="{{ b.datesUnavailable }}"
    data-msg-quote-error="{{ b.quoteError }}"
    data-msg-reservation-error="{{ b.reservationError }}"
    data-msg-config="{{ b.reservationPendingConfig }}"
    data-msg-created="{{ b.reservationCreated }}"
    data-msg-redirecting="{{ b.redirecting }}"
    data-msg-terms="{{ b.termsRequired }}"
    data-msg-complimentary-label="{{ b.complimentaryLabel or 'Complimentary' }}"
    data-msg-summary-empty-stay="{{ b.summaryEmptyStay }}"
    data-msg-summary-pending-amount="{{ b.summaryPendingAmount }}"
    data-msg-night-singular="{{ b.nightSingular or 'night' }}"
    data-msg-night-plural="{{ b.nightPlural or 'nights' }}"
    data-msg-calendar-prev="{{ b.calendarPrev or 'Previous month' }}"
    data-msg-calendar-next="{{ b.calendarNext or 'Next month' }}"
    data-msg-calendar-last-sync-prefix="{{ b.calendarLastSyncPrefix or 'Last Booking sync' }}"
    data-msg-calendar-arrival="{{ b.checkIn }}"
    data-msg-calendar-departure="{{ b.checkOut }}"
    data-msg-calendar-blocked-short="{{ b.calendarBlockedShort or b.calendarLegendBlocked or 'Unavailable' }}"
    data-msg-min-stay-template="{{ b.minimumStayErrorTemplate or 'Minimum stay: {nights} night(s).' }}"
    data-msg-min-stay-arrival-template="{{ b.minimumStayArrivalGuidanceTemplate or 'This arrival date does not allow the minimum stay of {nights} night(s).' }}"
  >
    <div class="card booking-main-card">
      <form
        id="booking-form"
        class="booking-form"
        toolname="{{ b.webMcpCheckoutToolName or 'start_parking_reservation_checkout' }}"
        tooldescription="{{ b.webMcpCheckoutToolDescription or 'Prepare a direct reservation checkout for the parking space, collect traveller details, create the reservation, and send the traveller to payment.' }}"
      >
        <section class="booking-section">
          <div class="booking-section-head">
            <h2 class="booking-section-title">{{ b.availabilityTitle }}</h2>
            <p class="text-sm text-muted">{{ b.datesHelp }}</p>
          </div>
          <div class="grid grid-cols-2 booking-two-cols">
            <div>
              <label class="form-label" for="booking-check-in">{{ b.checkIn }}</label>
              <input class="form-input" type="date" id="booking-check-in" name="checkInDate" required toolparamdescription="Arrival date for the stay in YYYY-MM-DD format.">
            </div>
            <div>
              <label class="form-label" for="booking-check-out">{{ b.checkOut }}</label>
              <input class="form-input" type="date" id="booking-check-out" name="checkOutDate" required toolparamdescription="Departure date for the stay in YYYY-MM-DD format.">
            </div>
          </div>
          <div class="booking-calendar-shell" aria-labelledby="booking-calendar-title">
            <div class="booking-calendar-head">
              <div>
                <h3 id="booking-calendar-title" class="booking-calendar-title">{{ b.calendarTitle or b.availabilityTitle }}</h3>
                <p class="text-sm text-muted booking-calendar-help">{{ b.calendarHelp or b.availabilityEnterDates }}</p>
              </div>
              <div class="booking-calendar-legend" aria-hidden="true">
                <span><i class="booking-calendar-dot booking-calendar-dot-available"></i>{{ b.calendarLegendAvailable or 'Available' }}</span>
                <span><i class="booking-calendar-dot booking-calendar-dot-selected"></i>{{ b.calendarLegendSelected or 'Selected' }}</span>
                <span><i class="booking-calendar-dot booking-calendar-dot-blocked"></i>{{ b.calendarLegendBlocked or 'Unavailable' }}</span>
              </div>
            </div>
            <div class="booking-calendar-toolbar">
              <div class="booking-calendar-sync text-sm text-muted" id="booking-calendar-sync"></div>
              <button class="booking-calendar-nav" type="button" id="booking-calendar-prev" aria-label="{{ b.calendarPrev or 'Previous month' }}">&#8249;</button>
              <button class="booking-calendar-nav" type="button" id="booking-calendar-next" aria-label="{{ b.calendarNext or 'Next month' }}">&#8250;</button>
            </div>
            <div class="booking-calendar-grid" id="booking-calendar-grid"></div>
          </div>
          <div class="booking-status" id="booking-availability-status">{{ b.availabilityEnterDates }}</div>
        </section>

        <section class="booking-section">
          <div class="booking-section-head">
            <h2 class="booking-section-title">{{ b.partyTitle }}</h2>
          </div>
          <div class="grid grid-cols-3 booking-three-cols">
            <div>
              <label class="form-label" for="booking-adults">{{ b.adults }}</label>
              <input class="form-input" type="number" id="booking-adults" name="adults" min="1" max="8" value="1" required toolparamdescription="Number of adult travellers.">
            </div>
            <div>
              <label class="form-label" for="booking-children">{{ b.children }}</label>
              <input class="form-input" type="number" id="booking-children" name="children" min="0" max="8" value="0" required toolparamdescription="Number of children under 16 years old.">
            </div>
            <div>
              {% if showVehicle %}
              <label class="form-label" for="booking-vehicle">{{ b.vehicleType }}</label>
              <select class="form-input" id="booking-vehicle" name="vehicleType" required toolparamdescription="Vehicle category for the reservation.">
                <option value="">{{ b.vehicleType }}</option>
                <option value="standard_car">{{ b.vehicleOptions.standard_car }}</option>
                <option value="car_roof_tent">{{ b.vehicleOptions.car_roof_tent }}</option>
                <option value="van">{{ b.vehicleOptions.van }}</option>
                <option value="caravan">{{ b.vehicleOptions.caravan }}</option>
                <option value="motorhome_upto_6_5m">{{ b.vehicleOptions.motorhome_upto_6_5m }}</option>
                <option value="motorhome_over_6_5m">{{ b.vehicleOptions.motorhome_over_6_5m }}</option>
              </select>
              {% elif showInfants %}
              <label class="form-label" for="booking-infants">{{ b.infants }}</label>
              <input class="form-input" type="number" id="booking-infants" name="infants" min="0" max="4" value="0" required toolparamdescription="Number of infants aged 0 to 2 years old.">
              {% else %}
              <input type="hidden" id="booking-vehicle" name="vehicleType" value="">
              <input type="hidden" id="booking-infants" name="infants" value="0">
              {% endif %}
            </div>
          </div>
          {% if b.partyHelp %}
          <p class="text-sm text-light booking-inline-note">{{ b.partyHelp }}</p>
          {% endif %}
        </section>

        <section class="booking-section">
          <div class="booking-section-head">
            <h2 class="booking-section-title">{{ b.optionsTitle }}</h2>
          </div>
          {% if showWcShower %}
          <label class="booking-checkbox">
            <input type="checkbox" id="booking-wc-shower" name="wcShowerRequested" toolparamdescription="Set to true to request indoor WC and shower access for the stay.">
            <span>{{ b.wcShower }}</span>
          </label>
          <p class="text-sm text-light booking-inline-note">{{ b.wcShowerNote }}</p>
          {% else %}
          <input type="hidden" id="booking-wc-shower" name="wcShowerRequested" value="">
          {% endif %}

          <label class="booking-checkbox">
            <input type="checkbox" id="booking-non-refundable" name="nonRefundableSelected" toolparamdescription="Set to true only if the traveller explicitly chooses the discounted non-refundable rate when eligible.">
            <span>{{ b.nonRefundable }}</span>
          </label>
          <p class="text-sm text-light booking-inline-note">{{ b.nonRefundableHint }}</p>
        </section>

        <section class="booking-section">
          <div class="booking-section-head">
            <h2 class="booking-section-title">{{ b.guestTitle }}</h2>
          </div>
          <div class="grid grid-cols-2 booking-two-cols">
            <div>
              <label class="form-label" for="booking-first-name">{{ b.firstName }}</label>
              <input class="form-input" type="text" id="booking-first-name" name="guestFirstName" required toolparamdescription="Guest first name.">
            </div>
            <div>
              <label class="form-label" for="booking-last-name">{{ b.lastName }}</label>
              <input class="form-input" type="text" id="booking-last-name" name="guestLastName" required toolparamdescription="Guest last name.">
            </div>
          </div>
          <div class="grid grid-cols-2 booking-two-cols">
            <div>
              <label class="form-label" for="booking-email">{{ b.email }}</label>
              <input class="form-input" type="email" id="booking-email" name="guestEmail" required toolparamdescription="Guest email address for confirmation and self-service management links.">
            </div>
            <div>
              <label class="form-label" for="booking-mobile-phone">{{ b.mobilePhoneLabel }}</label>
              <input class="form-input" type="tel" id="booking-mobile-phone" name="guestMobilePhone" required toolparamdescription="Guest mobile phone number for urgent contact during the stay.">
            </div>
          </div>
          <div class="grid grid-cols-2 booking-two-cols">
            <div>
              <label class="form-label" for="booking-date-of-birth">{{ b.dateOfBirthLabel }}</label>
              <input class="form-input" type="date" id="booking-date-of-birth" name="guestDateOfBirth" required toolparamdescription="Guest date of birth in YYYY-MM-DD format.">
            </div>
            <div></div>
          </div>
          <fieldset class="booking-fieldset">
            <legend class="booking-fieldset-legend">{{ b.addressLabel }}</legend>
            <div class="grid grid-cols-2 booking-two-cols">
              <div class="booking-field-wide">
                <label class="form-label" for="booking-address-street">{{ b.addressStreetLabel }}</label>
                <input class="form-input" type="text" id="booking-address-street" name="guestAddressStreet" required toolparamdescription="Guest street name and number.">
              </div>
            </div>
            <div class="grid grid-cols-3 booking-three-cols">
              <div>
                <label class="form-label" for="booking-address-zip">{{ b.addressZipLabel }}</label>
                <input class="form-input" type="text" id="booking-address-zip" name="guestAddressZip" required toolparamdescription="Guest ZIP / postal code.">
              </div>
              <div>
                <label class="form-label" for="booking-address-city">{{ b.addressCityLabel }}</label>
                <input class="form-input" type="text" id="booking-address-city" name="guestAddressCity" required toolparamdescription="Guest city / locality.">
              </div>
              <div>
                <label class="form-label" for="booking-address-country">{{ b.addressCountryLabel }}</label>
                <input class="form-input" type="text" id="booking-address-country" name="guestAddressCountry" required toolparamdescription="Guest country.">
              </div>
            </div>
          </fieldset>
          <div class="grid grid-cols-2 booking-two-cols">
            <div>
              <label class="form-label" for="booking-nationality">{{ b.nationalityLabel }}</label>
